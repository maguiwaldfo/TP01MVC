@using TP01.Models
@{
	ViewData["Title"] = "Info Integrante";

	var integrante = ViewBag.Integrante as Integrante;
	var dni = ViewBag.DNI ?? 0;

	string fotoFile = "";
	if (integrante != null)
	{
		fotoFile = integrante.obtenerFoto() ?? "";
		if (!fotoFile.Contains('.'))
		{
			fotoFile = fotoFile + ".png";
		}
	}
}

<div class="container mt-4">
	<h2>Información del integrante</h2>

	@if (integrante != null)
	{
		<div class="row">
			<div class="col-md-4">
				<img src="@Url.Content("~/images/" + fotoFile)" class="img-fluid img-thumbnail" alt="@integrante.obtenerNombre()" />
			</div>
			<div class="col-md-8">
				<h3>@integrante.obtenerNombre()</h3>
				<p><strong>DNI:</strong> @integrante.obtenerDni()</p>
				<p><strong>Fecha de nacimiento:</strong> @integrante.obtenerFechaNacimiento().ToString("dd/MM/yyyy")</p>

				<p><strong>Familiares:</strong></p>
				@if (integrante.obtenerFamiliares() != null && integrante.obtenerFamiliares().Count > 0)
				{
					<ul>
					@foreach (var fam in integrante.obtenerFamiliares())
					{
						<li>@fam</li>
					}
					</ul>
				}
				else
				{
					<p>No hay familiares cargados.</p>
				}

				<p><strong>Intereses:</strong></p>
				@if (integrante.obtenerIntereses() != null && integrante.obtenerIntereses().Count > 0)
				{
					<ul>
					@foreach (var it in integrante.obtenerIntereses())
					{
						<li>@it</li>
					}
					</ul>
				}
				else
				{
					<p>No hay intereses cargados.</p>
				}

			</div>
		</div>
	}
	else
	{
		<p>No se encontró el integrante con DNI @dni.</p>
	}

	<div class="mt-3">
		<a class="btn btn-secondary" href="@Url.Action("Index", "Home")">Volver al índice</a>
	</div>
</div>

